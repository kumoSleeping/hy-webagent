# Server
PORT=3001
CORS_ORIGIN=http://localhost:5173
WORKSPACE_ROOT=./workspaces
DATABASE_PATH=./data/platform.db

# Optional admin break-glass key
# ADMIN_KEY=

# Bundled PI extensions (default: ./pi-extensions)
# PI_EXTENSIONS_ROOT=./pi-extensions

# PI extension secrets — prefer auth.json (provider "jina"); env is optional fallback
# JINA_API_KEY=
# VISION_MODEL=xiaomi/mimo-v2.5

# Model template providers (for restricted users — see server/config/model-templates.json)
# DEEPSEEK_API_KEY=
# XIAOMI_API_KEY=
